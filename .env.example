# Database (PostgreSQL — Supabase or any Postgres host)
# For Supabase: use the "Direct connection" URL (port 5432) from Settings → Database
# For local dev with Supabase: same URL works
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Direct connection URL (bypasses pooler, used for Prisma migrations)
DIRECT_URL="postgresql://user:password@host:5432/dbname"

# Auth.js (required — must be set on every deployment)
# Generate: openssl rand -base64 32
AUTH_SECRET=""

# Required on non-Vercel hosts (Hostinger, VPS, etc.) — Auth.js will not work without this
# Set to the exact public URL of the deployment, no trailing slash
AUTH_URL="https://your-domain.com"

# Bootstrap admin token (required for /api/dev/bootstrap-admin)
# Set to any strong random string; used to seed the initial admin user
BOOTSTRAP_ADMIN_TOKEN=""

# Admin user credentials for bootstrap endpoint
BOOTSTRAP_ADMIN_EMAIL="admin@mailsifu.com"
BOOTSTRAP_ADMIN_PASSWORD=""

# Resend API key (required for domain management)
# Get from Resend Dashboard → API Keys
RESEND_API_KEY=""

# Resend inbound webhook (required in production)
# Signing secret from Resend Dashboard → Webhooks → your endpoint → Signing Secret
# Format: whsec_<base64>  (Svix standard)
RESEND_WEBHOOK_SECRET=""

# Domain you configured in Resend for inbound email routing
# e.g. inbound.mailsifu.com or rx.mailsifu.com
RESEND_INBOUND_DOMAIN=""

# Forward Email (alternative inbound provider)
# API key from Forward Email dashboard
FORWARD_EMAIL_API_KEY=""

# Webhook signing secret for Forward Email inbound webhooks
# HMAC-SHA256 verification via X-Webhook-Signature header
FORWARD_EMAIL_WEBHOOK_SECRET=""
